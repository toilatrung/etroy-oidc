{
  "name": "etroy-oidc",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "eTroy OIDC - OpenID Connect Provider and Identity Layer for the eTroy ecosystem",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"*.{json,md,mjs}\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"*.{json,md,mjs}\""
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^5.1.0",
    "ioredis": "^5.4.1",
    "mongoose": "^8.13.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/node": "^22.13.11",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.1",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
